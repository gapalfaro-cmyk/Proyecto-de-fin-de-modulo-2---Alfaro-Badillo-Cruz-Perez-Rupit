from datetime import date, datetime

def generar_trimestres(año_inicio=1995, año_fin=None):
    if año_fin is None:
        año_fin = datetime.strptime(end_date, "%Y-%m-%d").year

    trimestres = []
    meses = [("01-01", "03-31"), ("04-01", "06-30"), ("07-01", "09-30"), ("10-01", "12-31")]

    for año in range(año_inicio, año_fin + 1):
        for start_m, end_m in meses:
            start = f"{año}-{start_m}"
            end   = f"{año}-{end_m}"

            # Ajustar inicio del primer trimestre histórico
            if start < "1995-06-16":
                start = "1995-06-16"

            hoy = str(end_date)
            if start > hoy:
                break
            if end > hoy:
                end = hoy

            trimestres.append((start, end))

    return trimestres

